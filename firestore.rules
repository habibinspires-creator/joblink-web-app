rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: only the user themselves can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Jobs collection: anyone can read active jobs, only employers can post/edit
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.employerId;
    }
  }
}
